# EditorConfig
# • Define formatting conventions for textual files in the project.

root = true

[*]
indent_style = tab
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{js,ts}]
indent_size = 2

[*.{html,css}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
