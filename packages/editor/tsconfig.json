{
  "extends": "../../tsconfig.json",

  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": false,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@litepen/editor": ["./index.ts"],
      "@litepen/editor/*": ["./src/*"],
      "@/*": ["./src/*"],
      "assets/*": ["./assets/*"],
      "factories/*": ["./factories/*"],
      "logger/*": ["./src/shared/logger/*"],
      "styles/*": ["./styles/*"]
    }
  },
  "include": [
    "factories",
    "index.ts",
    "public-types.ts",
    "src/**/*",
    "vite.config.js"
  ]
}
