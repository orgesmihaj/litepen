{
  "name": "@litepen/editor",
  "description": "A lightweight, extensible text editor",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/public-types.d.ts"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "dev:release": "vite build --watch",
    "build": "vite build && rm -f tsconfig.tsbuildinfo && tsc --emitDeclarationOnly --declaration",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@litepen/conventions": "workspace:*",
    "jsdom": "^28.1.0",
    "postcss": "8.5.6",
    "postcss-preset-env": "^11.2.0",
    "sass": "^1.93.2",
    "vite": "7.3.1",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vitest": "4.0.18"
  }
}
