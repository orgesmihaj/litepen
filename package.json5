{
	"name": "@litepen/editor",
	"version": "1.0.0",
	"description": "A modern touch to your editor.",
	"keywords": ["litepen", "editor", "WYSIWYG"],
	"author": "Orges Mihaj",
	"license": "ISC",

	"files": ["dist"],
	"workspaces": ["packages/*"],
	"type": "module",
	"main": "./dist/composer.umd.cjs",
	"module": "./dist/composer.js",
	"exports": {
		".": {
			"import": "./dist/composer.js",
			"require": "./dist/composer.umd.cjs",
			"types": "./types/composer.d.ts"
		}
	},

	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"test": "vitest"
	},

	"devDependencies": {
		"@litepen/conventions": "workspace:*",
		"@biomejs/biome": "1.6.3",
		"jsdom": "^24.0.0",
		"sass": "^1.72.0",
		"typescript": "5.4.3",
		"vite": "5.2.7",
		"vitest": "^1.4.0",
	},

	"repository": {
		"type": "git",
		"url": "git+https://github.com/orgesmihaj/litepen.git"
	},

	"bugs": {
		"url": "https://github.com/orgesmihaj/litepen/issues"
	}
}
