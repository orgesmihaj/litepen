{
  "name": "@litepen/monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter playground --filter editor dev",
    "build": "pnpm --filter editor build",
    "build:all": "pnpm --filter \"./packages/*\" build",
    "test": "pnpm --filter editor test",
    "test:all": "pnpm --filter \"./packages/*\" test",
    "lint": "pnpm --filter \"./packages/*\" lint",
    "format": "pnpm --filter \"./packages/*\" format",
    "clean": "pnpm --filter \"./packages/*\" clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}