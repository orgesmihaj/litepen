{
	"name": "@litepen/core",
	"version": "1.0.0",
	"license": "ISC",
	"author": "Orges Mihaj",
	"description": "An extremely easy-to-install WYSIWYG editor of modern times. Focused on creating semantic content.",
	"keywords": [
		"editor",
		"WYSIWYG",
		"JS",
		"JavaScript"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"workspaces": [
		"packages/*"
	],
	"main": "./dist/composer.umd.cjs",
	"module": "./dist/composer.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/composer.js",
			"require": "./dist/composer.umd.cjs"
		}
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"serve": "vite preview",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"lint": "eslint --ext .js,.jsx --ignore-path .gitignore --fix src",
		"lint:fix": "npm run lint -- --fix",
		"prettier": "npx prettier src test --check",
		"prettier:fix": "npm run prettier -- --write",
		"format": "npm run prettier:fix && npm run lint:fix"
	},
	"devDependencies": {
		"@litepen/eslint": "^1.0.0",
		"jsdom": "^22.1.0",
		"prettier": "2.8.8",
		"sass": "^1.63.2",
		"typescript": "5.1.3",
		"vite": "^4.3.9",
		"vitest": "^0.32.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/orgesmihaj/litepen.git"
	},
	"bugs": {
		"url": "https://github.com/orgesmihaj/litepen/issues"
	}
}
