{
	"name": "@litepen/core",
	"version": "1.0.0",
	"description": "An extremely easy-to-install WYSIWYG editor of modern times. Focused on creating semantic content.",
	"author": "Orges Mihaj (https://mihaj.org)",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"serve": "vite preview",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"lint": "eslint --ext .js,.jsx --ignore-path .gitignore --fix src",
		"lint:fix": "npm run lint -- --fix",
		"prettier": "npx prettier src test --check",
		"prettier:fix": "npm run prettier -- --write",
		"format": "npm run prettier:fix && npm run lint:fix"
	},
	"keywords": [
		"editor",
		"WYSIWYG",
		"JS",
		"JavaScript"
	],
	"license": "ISC",
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "^5.59.9",
		"@typescript-eslint/parser": "^5.59.9",
		"eslint": "^8.42.0",
		"eslint-config-airbnb-base": "^15.0.0",
		"eslint-config-airbnb-typescript": "^17.0.0",
		"eslint-config-prettier": "^8.8.0",
		"eslint-plugin-import": "^2.27.5",
		"jsdom": "^22.1.0",
		"prettier": "2.8.8",
		"sass": "^1.63.2",
		"typescript": "5.1.3",
		"vite": "^4.3.9",
		"vitest": "^0.32.0"
	},
	"files": [
		"dist"
	],
	"main": "./dist/composer.umd.cjs",
	"module": "./dist/composer.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/composer.js",
			"require": "./dist/composer.umd.cjs"
		}
	}
}
